# ─────────────────────────────────────────────────────────────
# SIGNALIST — Environment Variables
# Copy this to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/signalist?retryWrites=true&w=majority

# Better-Auth  (generate: openssl rand -base64 32)
BETTER_AUTH_SECRET=your_64_char_secret_here
BETTER_AUTH_URL=http://localhost:3000

# Finnhub  — SERVER SIDE ONLY. Never use NEXT_PUBLIC_ for API keys!
FINNHUB_API_KEY=your_finnhub_api_key_here

# Inngest
INNGEST_SIGNING_KEY=signkey-prod-xxxxxxxxxxxxxxxx
INNGEST_EVENT_KEY=your_inngest_event_key

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
